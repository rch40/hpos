{
  "name": "hpos",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "build:backend": "npm run build -w packages/contracts && npm run build -w apps/backend",
    "build:frontend": "npm run build -w packages/contracts && npm run build -w apps/frontend",
    "start:backend": "node apps/backend/dist/server.js",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "dev:backend": "npm run dev -w apps/backend",
    "dev:frontend": "npm run dev -w apps/frontend"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
